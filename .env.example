# ======================================================================
# OpenPup configuration. Copy to `.env` and fill in what you need.
# Every section is optional — only configure the platforms you want on.
# ======================================================================

# ---- Identity & agent ------------------------------------------------
OPENPUP_NAME=OpenPup
OPENPUP_AGENT=code-puppy
# Persona presets used to generate ~/.openpup/SOUL.md (edit via `openpup persona`).
# personality: warm_loyal_sassy | sharp_dry | calm_pro | chaotic_retriever
OPENPUP_PERSONALITY=warm_loyal_sassy
# proactivity: relentless | proactive | balanced | reserved
OPENPUP_PROACTIVITY=relentless
# Model name as configured in your code-puppy setup (~/.code_puppy).
# Leave blank to use code-puppy's global default model.
OPENPUP_MODEL=
# Optional cheaper model used for low-stakes heartbeat reflection ticks.
OPENPUP_REFLECTION_MODEL=
# Universal Constructor: let the agent build its own tools at runtime (create/call/list).
OPENPUP_UNIVERSAL_CONSTRUCTOR=true

# ---- Owner / human ---------------------------------------------------
# Primary owner address (default destination for proactive outreach): "platform:channel"
# e.g. telegram:123456789  or  discord:998877  or  sms:+15559876543 (YOUR cell)
OPENPUP_OWNER_ADDRESS=
# Owner across multiple platforms (comma-separated). The owner is recognized and
# reachable at ANY of these, e.g. "telegram:123456789,sms:+15559876543".
OPENPUP_OWNER_ADDRESSES=

# ---- Outbound comms governance --------------------------------------
# Who the agent may message: open | contacts | owner_only
OPENPUP_SEND_POLICY=open
# Per-platform outbound message cap per minute (runaway/spam guard).
OPENPUP_SEND_RATE_PER_MIN=10

# ---- Memory (puppy_kennel) ------------------------------------------
PUPPY_KENNEL_ROOT=~/.openpup/kennel

# ---- Heartbeat -------------------------------------------------------
OPENPUP_HEARTBEAT_ENABLED=true
# Base seconds between heartbeat ticks.
OPENPUP_HEARTBEAT_INTERVAL=900
# Random +/- jitter (seconds) applied to each interval.
OPENPUP_HEARTBEAT_JITTER=120
# Behaviors: any of reflect,outreach,routines,inbound (comma separated)
OPENPUP_HEARTBEAT_BEHAVIORS=reflect,outreach,routines,inbound
# Quiet hours (24h local), no proactive outreach in this window. Blank = always.
OPENPUP_QUIET_HOURS=23-7
# Max proactive outreach messages per day (spam guard).
OPENPUP_OUTREACH_MAX_PER_DAY=4

# ---- Webhook server (WhatsApp / SMS / Telegram-webhook inbound) ------
OPENPUP_WEB_ENABLED=false
OPENPUP_WEB_HOST=0.0.0.0
OPENPUP_WEB_PORT=8080
OPENPUP_WEBHOOK_SECRET=

# ---- Discord ---------------------------------------------------------
DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=

# ---- Telegram --------------------------------------------------------
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=

# ---- WhatsApp (Meta Cloud API) --------------------------------------
WHATSAPP_ENABLED=false
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ---- Email (IMAP in / SMTP out) -------------------------------------
EMAIL_ENABLED=false
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_POLL_SECONDS=60

# ---- SMS (Twilio) ----------------------------------------------------
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# The Twilio-OWNED number you bought (the SENDER), in E.164. NOT your cell.
TWILIO_FROM_NUMBER=
# (Your personal cell goes in OPENPUP_OWNER_ADDRESS / OPENPUP_OWNER_ADDRESSES as sms:+1...)
